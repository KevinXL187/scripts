[Unit]
Description=Ollama Service
After=network-online.target

[Service]
ExecStart=/usr/local/bin/ollama serve
User=ollama
Group=ollama
Restart=no
# RestartSec=3
Environment="PATH=/home/xinghai/.local/bin:/home/xinghai/bin:/usr/local/bin:/usr/bin:/bin:/usr/local/sbin:/usr/sbin:/sbin"
Environment="OLLAMA_MODELS=/mnt/linux_data/Local Chatbot/models/ollama_models/"
[Install]
WantedBy=default.target
